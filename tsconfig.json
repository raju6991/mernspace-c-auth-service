{
    "compilerOptions": {
        "target": "es2016",
        "lib": ["es6"],
        "module": "commonjs",
        "rootDir": "./",
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "skipLibCheck": true,
        "sourceMap": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "ignoreDeprecations": "5.0",
        "types": ["jest", "node"]
    },

    //TypeOrm

    "emitDecoratorMetaData": true,
    "expeirmentalDecorators": true,

    "include": ["src/**/*.ts", "tests/**/*.ts", "app.spec.ts", "jest.config.ts", "scripts/**/.js"],

    "exclude": ["dist", "node_modules"]
}
