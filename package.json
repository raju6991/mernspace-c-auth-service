{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "The user management service",
    "homepage": "https://github.com/raju6991/mernspace-c-auth-service#readme",
    "bugs": {
        "url": "https://github.com/raju6991/mernspace-c-auth-service/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/raju6991/mernspace-c-auth-service.git"
    },
    "license": "ISC",
    "author": "Raju Lamsal",
    "main": "index.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon src/server.ts",
        "build": "tsc",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "eslint",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --no-cache --coverage --all --runInBand",
        "test:watch": "jest --watch --watchAll=true --runInBand",
        "prepare": "husky",
        "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/data-source.ts",
        "migration:create": "typeorm-ts-node-commonjs migration:create",
        "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/data-source.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.5.0",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "cross-env": "^10.1.0",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "mock-jwks": "^1.0.10",
        "nodemon": "^3.1.14",
        "prettier": "3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.0",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "express-validator": "^7.3.2",
        "http-errors": "^2.0.1",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^3.2.2",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "rsa-pem-to-jwk": "^1.1.3",
        "typeorm": "^0.3.28",
        "winston": "^3.19.0"
    }
}
